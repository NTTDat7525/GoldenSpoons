APP_NAME="Golden Spoons"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=golden_spoons
DB_USERNAME=root
DB_PASSWORD=

# Cache / Session
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail (OTP / xác nhận booking)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@goldenspoons.com"
MAIL_FROM_NAME="Golden Spoons"

# Google Login (Laravel Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# SePay Payment (webhook thanh toán)
SEPAY_API_KEY=
SEPAY_WEBHOOK_SECRET=
SEPAY_ACCOUNT_NUMBER=

# Filesystem
FILESYSTEM_DISK=public

# Queue (nếu có gửi mail async)
QUEUE_CONNECTION=sync